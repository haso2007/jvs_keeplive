# Copy to `.env` on the NAS before `docker compose up -d --build`.

# Build-time proxy for pulling Python packages and Playwright browser archives.
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1

# Optional faster PyPI mirror in mainland China.
PIP_INDEX_URL=
PIP_EXTRA_INDEX_URL=

# Optional Playwright download mirror.
PLAYWRIGHT_DOWNLOAD_HOST=
PLAYWRIGHT_CHROMIUM_DOWNLOAD_HOST=

# Increase Playwright browser download timeout from the default 30000ms.
PLAYWRIGHT_DOWNLOAD_CONNECTION_TIMEOUT=180000
